#!/bin/sh /etc/rc.common

# Service priority in boot sequence
START=99
STOP=10

USE_PROCD=1
PROG=/usr/bin/ntrip-stream.sh

start_service() {
    # Ensure the environment is ready
    if [ ! -f "/usr/bin/ntripclient.exe" ]; then
        if [ -f "/usr/bin/ntripclient" ]; then
            mv /usr/bin/ntripclient /usr/bin/ntripclient.exe
        else
            echo "Error: ntripclient binary not found!"
            exit 1
        fi
    fi

    procd_open_instance
    procd_set_param command /bin/sh "$PROG"
    procd_set_param respawn ${respawn_threshold:-3600} ${respawn_timeout:-5} ${respawn_retry:-5}
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

stop_service() {
    killall -9 ntripclient.exe 2>/dev/null
}