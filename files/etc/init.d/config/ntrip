config client 'client'
    option server 'my_server'
    option port '2101'
    option mode 'ntrip1'
    option user 'my_login'
    option password 'my_password'
    option serial_port '/dev/ttyS0'
    option temp_file '/tmp/ntrip_corrections.log'
    option disabled '1'
    list mountpoint 'MOUNT_1'
    list mountpoint 'MOUNT_2'